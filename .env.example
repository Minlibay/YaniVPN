# ============ Локальная разработка ============
# PostgreSQL: проще всего поднять контейнером:
#   docker run -d --name yanivpn-db -p 5432:5432 \
#     -e POSTGRES_DB=yanivpn -e POSTGRES_USER=yanivpn -e POSTGRES_PASSWORD=yanivpn \
#     postgres:16-alpine
DATABASE_URL="postgresql://yanivpn:yanivpn@localhost:5432/yanivpn"

# Секрет для подписи сессионных JWT (сгенерируйте: openssl rand -hex 32)
AUTH_SECRET="change-me-to-a-long-random-string"

# Публичный адрес панели — прописывается агентам нод при автоустановке.
# Если не задан, берётся адрес, с которого пришёл запрос (годится для dev).
# PANEL_URL="https://panel.yanivpn.space"

# Учётные данные администратора, создаваемые сидом
ADMIN_EMAIL="admin@yanivpn.local"
ADMIN_PASSWORD="admin123"

# ============ Docker-деплой (docker compose up -d) ============
# Эти переменные читает docker-compose.yml; для локальной разработки не нужны.
# DOMAIN="panel.yanivpn.space"
# ACME_EMAIL="an.volovod@yandex.ru"
# POSTGRES_PASSWORD="сгенерируйте: openssl rand -hex 16"
