# SQLite по умолчанию; для продакшена замените на PostgreSQL,
# например: postgresql://user:password@localhost:5432/yanivpn
DATABASE_URL="file:./dev.db"

# Секрет для подписи сессионных JWT (сгенерируйте: openssl rand -hex 32)
AUTH_SECRET="change-me-to-a-long-random-string"

# Публичный адрес панели — прописывается агентам нод при автоустановке.
# Если не задан, берётся адрес, с которого пришёл запрос (годится для dev).
# PANEL_URL="https://panel.example.com"

# Учётные данные администратора, создаваемые сидом
ADMIN_EMAIL="admin@yanivpn.local"
ADMIN_PASSWORD="admin123"
