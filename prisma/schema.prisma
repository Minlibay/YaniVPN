generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Администратор панели
model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

// Аккаунт пользователя мобильного приложения. Регистрации нет: при первом
// запуске приложение получает `code` — портативную личность, которую можно
// перенести на другое устройство и продолжить пользоваться VPN.
model Account {
  id        String   @id @default(cuid())
  code      String   @unique // конфигурационный код (секрет, живёт на устройствах)
  plan      String   @default("free") // free | paid
  dataLimit BigInt   @default(2147483648) // лимит трафика для free: 2 ГБ
  createdAt DateTime @default(now())

  peers Peer[]
}

// VPN-сервер (нода). На каждой ноде работает выбранный протокол + агент,
// который авторизуется по apiToken и отправляет статистику.
model Server {
  id       String @id @default(cuid())
  name     String
  host     String // публичный IP или домен
  port     Int    @default(51820)
  country  String // ISO-код страны, например "NL"
  city     String @default("")
  // wireguard | awg (AmneziaWG) | vless (VLESS+Reality, обход блокировок)
  protocol  String @default("wireguard")
  publicKey String @default("") // WG/AWG: pubkey интерфейса; VLESS: Reality public key (отдаётся клиентам)
  apiToken  String @unique // токен для агента ноды

  // Параметры VLESS+Reality (заполняются автоустановкой)
  realityPrivateKey String @default("")
  realityShortId    String @default("") // один или несколько short id Reality (CSV)
  realitySni        String @default("") // домен маскировки, напр. www.microsoft.com

  // Транспорт VLESS: reality (прямое) или ws (WebSocket за Cloudflare/CDN).
  vlessTransport String @default("reality")
  vlessDomain    String @default("") // домен за CDN (ws)
  vlessPath      String @default("") // ws-путь, напр. /a1b2c3

  // Параметры обфускации AmneziaWG (JSON: Jc/Jmin/Jmax/S1/S2/H1..H4).
  // Одинаковы на сервере и клиентах; генерируются при создании ноды.
  awgParams String @default("")

  // installing → active | error; active = протокол и агент установлены
  status         String  @default("active")
  provisionError String? // хвост лога установки при статусе error
  lastSeenAt     DateTime? // последний отчёт агента; определяет online/offline
  createdAt      DateTime @default(now())

  peers   Peer[]
  samples StatSample[]
}

// Клиент. Идентификатор зависит от протокола сервера:
// WireGuard — пара ключей + адрес в туннеле; VLESS — UUID.
// Позже станет учёткой пользователя мобильного приложения.
model Peer {
  id              String    @id @default(cuid())
  name            String
  publicKey       String?   @unique // WireGuard: публичный ключ клиента
  allowedIp       String    @default("") // WireGuard: адрес в туннеле, напр. 10.8.0.5/32
  uuid            String?   @unique // VLESS: UUID клиента
  enabled         Boolean   @default(true)
  lastHandshakeAt DateTime? // последняя активность (WG: handshake, VLESS: движение трафика)
  rxBytes         BigInt    @default(0) // всего принято сервером от клиента
  txBytes         BigInt    @default(0) // всего отправлено клиенту
  createdAt       DateTime  @default(now())

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  // Пиры, выпущенные через приложение, привязаны к аккаунту (для учёта квоты).
  // Пиры, созданные вручную в панели, аккаунта не имеют.
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@index([accountId])
}

// Срез статистики по серверу; пишется при каждом отчёте агента.
// По этим точкам строятся графики на дашборде.
model StatSample {
  id          String   @id @default(cuid())
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  activePeers Int // пиры с handshake за последние 3 минуты
  rxBytes     BigInt // суммарный rx по всем пирам на момент среза
  txBytes     BigInt
  sampledAt   DateTime @default(now())

  @@index([serverId, sampledAt])
}
